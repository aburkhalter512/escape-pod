# Discord application credentials (Discord Developer Portal)
DISCORD_APPLICATION_ID=
DISCORD_PUBLIC_KEY=
DISCORD_BOT_TOKEN=

# Postgres connection string — matches scripts/db.sh's container
# (npm run db:up / npm run dev brings it up automatically)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/draft_pod

# AES-256-GCM key for encrypting PTP tokens at rest (INTEGRATIONS.md §8.5).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=

# Protects this service's own internal HTTP API (/organizers/*, /guilds/*,
# /pods/*) — a bearer-protected debug/admin surface, Authorization: Bearer <key>
BOT_API_KEY=

# Protect the Pod base URL
PTP_BASE_URL=https://www.protectthepod.com

PORT=3000
